{
  "manifest_version": 3,
  "name": "DeCode",
  "version": "0.1.1",
  "description": "A developer tool that decodes or encodes any text you select on a webpage. Supports common formats like Base64, URL encoding, JWT, and Hex.",
  "permissions": [],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content_bundle.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [],
  "icons": {
    "16": "icons/de-16.png",
    "48": "icons/de-48.png",
    "128": "icons/de-128.png"
  }
}
